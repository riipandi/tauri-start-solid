{
  "name": "tauri-start-solid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:ui": "vite dev",
    "build:ui": "vite build",
    "start": "pnpm dlx serve dist -l 3000 -s -n -C",
    "update-deps": "npm-check-updates --configFileName .ncurc.json",
    "test:report": "pnpm dlx serve tests-results -l 8000 -s -n -C",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test": "vitest --run",
    "typecheck": "tsc -b --noEmit",
    "check": "oxfmt --check && oxlint",
    "format": "oxfmt --write .",
    "lint": "oxlint --fix",
    "tauri": "tauri"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@tanstack/solid-router": "^1.166.7",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/css-utils": "^0.1.6",
    "@vanilla-extract/dynamic": "^2.1.5",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.166.12",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@vanilla-extract/vite-plugin": "^5.2.0",
    "npm-check-updates": "^19.6.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "pathe": "^2.0.3",
    "solid-devtools": "^0.34.5",
    "typescript": "^6.0.1-rc",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lightningcss"
    ]
  }
}
